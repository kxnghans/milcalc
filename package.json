{
  "name": "milcalc",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "milcalc:dev": "pnpm --filter milcalc-mobile dev",
    "milcalc:clear": "pnpm --filter milcalc-mobile dev:clear",
    "milcalc:tunnel": "pnpm --filter milcalc-mobile dev --tunnel",
    "milcalc:remote": "pnpm --filter milcalc-mobile dev:clear --tunnel",
    "data:export": "ts-node packages/utils/scripts/export-standards.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "pnpm --stream -r test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.17",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "turbo": "latest",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-native-reanimated": "4.1.5",
      "@expo/vector-icons": "15.0.3",
      "@types/react": "19.1.10"
    },
    "ignoredBuiltDependencies": [
      "core-js-pure"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.74.0",
    "dotenv": "^17.2.3",
    "expo-image": "^3.0.10",
    "react-native-gesture-handler": "^2.28.0"
  }
}